{
  "compilerOptions": {
    "noImplicitAny": false,
    "strictNullChecks": false,
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "noImplicitThis": true,
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "outDir": "dist",
    "lib": ["esnext", "dom"],
    "types": [
      "@dcloudio/types",
      "@uni-helper/uni-types",
      "@types/wechat-miniprogram",
      "wot-design-uni/global.d.ts"
    ]
  },
  "vueCompilerOptions": {
    "target": 3,
    "plugins": ["@uni-helper/uni-types/volar-plugin"],
    "extensions": [".vue", ".nvue"]
  },
  "exclude": ["node_modules", "*.nvue"],
  "include": [
    "src/**/*.nvue",
    "static/**/*",
    "src/**/*.ts",
    "src/**/*.js",
    "src/**/*.d.ts",
    "src/**/*.tsx",
    "src/**/*.jsx",
    "src/**/*.vue",
    "src/**/*.json",
    "node_modules/.pnpm/mp-html@2.5.0/node_modules/mp-html/src/uni-app/static/app-plus/mp-html/js/handler.js"
  ]
}
